---
import Layout from '../layouts/Layout.astro';
import { getDb } from '../lib/db';
import { formatDate, formatPrice } from '../lib/slugify';
import type { Camp, Seminar } from '../lib/db';

const db = getDb();
const camps = db.prepare("SELECT * FROM camps WHERE active=1 AND date(date_from) >= date('now') ORDER BY sort_order, date_from LIMIT 3").all() as Camp[];
const seminars = db.prepare("SELECT * FROM seminars WHERE active=1 AND date(date_from) >= date('now') ORDER BY sort_order, date_from LIMIT 3").all() as Seminar[];
const upcoming = [...camps.map(c => ({...c, kind: 'camp' as const})), ...seminars.map(s => ({...s, kind: 'seminar' as const}))]
  .sort((a, b) => a.date_from.localeCompare(b.date_from))
  .slice(0, 4)
  .map(item => ({
    ...item,
    spotsLeft: 'spots_left' in item ? (item as Camp).spots_left : null,
    fewSpots: 'spots_left' in item && (item as Camp).spots_left > 0 && (item as Camp).spots_left < 4,
    href: `/${item.kind === 'camp' ? 'tabory' : 'seminare'}/${item.slug}`,
    kindLabel: item.kind === 'camp' ? 'Tábor' : 'Seminář',
    kindClass: item.kind === 'camp' ? 'bg-[#e8f5ec] text-[#3d7a4a]' : 'bg-[#fef3dc] text-[#c07818]',
    kindEmoji: item.kind === 'camp' ? '🏕️' : '🎓',
  }));
---

<Layout>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[#e8f5ec] via-[#faf8f3] to-[#fef3dc] pt-16 pb-24">
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#3d7a4a]/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#f5a623]/10 rounded-full translate-y-1/2 -translate-x-1/2"></div>
    <div class="max-w-6xl mx-auto px-4 relative">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-flex items-center gap-2 bg-[#e8f5ec] text-[#3d7a4a] text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
            🌿 Certifikovaná výživová poradkyně
          </span>
          <h1 class="text-4xl md:text-5xl font-black text-[#2c2c2c] leading-tight mb-6">
            Naučte svou rodinu<br/>
            <span class="text-[#3d7a4a]">zdravý vztah k jídlu</span>
          </h1>
          <p class="text-lg text-gray-600 leading-relaxed mb-8">
            Jíst zdravě nemusí být žádná fuška. Může to být kulinářské dobrodružství pro celou rodinu.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/tabory" class="btn-primary">🏕️ Letní tábory</a>
            <a href="/poradenstvi" class="btn-outline">Výživové poradenství</a>
          </div>
          <div class="mt-8 flex items-center gap-6 text-sm text-gray-500">
            <div class="flex items-center gap-2"><span class="text-[#f5a623] text-lg">★★★★★</span> Reference</div>
            <div>|</div>
            <div>Písek & online</div>
          </div>
        </div>
        <div class="relative">
          <div class="w-full aspect-square max-w-md mx-auto rounded-3xl bg-gradient-to-br from-[#3d7a4a]/10 to-[#f5a623]/10 flex items-center justify-center">
            <img src="/images/logo-vertical.png" alt="Pro zdravé děti" class="w-2/3 h-auto drop-shadow-lg" />
          </div>
          <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-lg p-4 flex items-center gap-3">
            <div class="w-10 h-10 bg-[#e8f5ec] rounded-xl flex items-center justify-center text-xl">🥗</div>
            <div>
              <div class="text-xs text-gray-500">Specializace</div>
              <div class="text-sm font-bold text-[#2c2c2c]">Výživa dětí</div>
            </div>
          </div>
          <div class="absolute -top-4 -right-4 bg-white rounded-2xl shadow-lg p-4 flex items-center gap-3">
            <div class="w-10 h-10 bg-[#fef3dc] rounded-xl flex items-center justify-center text-xl">🏕️</div>
            <div>
              <div class="text-xs text-gray-500">Každé léto</div>
              <div class="text-sm font-bold text-[#2c2c2c]">Příměstské tábory</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Nadcházející akce -->
  {upcoming.length > 0 && (
    <section class="section">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-3xl font-black text-[#2c2c2c]">Nejbližší akce</h2>
          <p class="text-gray-500 mt-1">Přihlaste se včas, míst je vždy málo!</p>
        </div>
        <div class="hidden sm:flex gap-3">
          <a href="/tabory" class="btn-outline text-sm">Tábory</a>
          <a href="/seminare" class="btn-outline text-sm">Semináře</a>
        </div>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {upcoming.map((item) => (
          <a href={item.href} class="card group cursor-pointer block">
            {item.poster_url ? (
              <img src={item.poster_url} alt={item.title} class="w-full aspect-[3/4] object-cover" />
            ) : (
              <div class="w-full aspect-[3/4] bg-gradient-to-br from-[#e8f5ec] to-[#f0ebe0] flex items-center justify-center text-6xl">
                {item.kindEmoji}
              </div>
            )}
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${item.kindClass}`}>
                  {item.kindLabel}
                </span>
                {item.fewSpots &&
                  <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-red-50 text-red-600">
                    Poslední {item.spotsLeft} místa!
                  </span>
                }
              </div>
              <h3 class="font-bold text-lg text-[#2c2c2c] group-hover:text-[#3d7a4a] transition-colors mb-1">{item.title}</h3>
              <p class="text-sm text-gray-500 mb-3">📅 {formatDate(item.date_from)} · {item.location}</p>
              {item.price !== null && item.price !== undefined && (
                <p class="font-bold text-[#3d7a4a] text-lg">{formatPrice(item.price as number)}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- O Lence -->
  <section class="bg-[#e8f5ec] py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1">
          <span class="text-[#3d7a4a] font-semibold text-sm">👋 Ahoj!</span>
          <h2 class="text-3xl font-black text-[#2c2c2c] mt-2 mb-4">Jmenuji se Lenka</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            Jsem certifikovaná výživová poradkyně se specializací na výživu dětí. Věřím, že správné stravování není o striktních dietách — je to o radosti z jídla a zdravých návycích od malička.
          </p>
          <p class="text-gray-700 leading-relaxed mb-6">
            Specializuji se na výživu od těhotenství, kojení, výživu kojenců a dětí až po zdravou rodinou stravu. Mé tábory a semináře jsou plné smíchu, vaření a nových chutí.
          </p>
          <a href="/o-mne" class="btn-primary">Více o mně</a>
        </div>
        <div class="order-1 md:order-2 flex justify-center">
          <div class="w-64 h-64 rounded-3xl bg-gradient-to-br from-[#3d7a4a]/20 to-[#f5a623]/20 flex items-center justify-center text-8xl shadow-inner">
            🌱
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Služby -->
  <section class="section">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-black text-[#2c2c2c]">S čím vám pomohu</h2>
      <p class="text-gray-500 mt-2">Od těhotenství po školní věk — provázím vás celou cestou</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        { icon: '🏕️', title: 'Příměstské tábory', desc: 'Týdenní kulinářské dobrodružství plné vaření, poznávání potravin a zdravého jídla.', href: '/tabory', label: 'Tábory na léto' },
        { icon: '🎓', title: 'Semináře & kurzy', desc: 'Přednášky a praktické workshopy pro rodiče i školy. Online i prezenčně.', href: '/seminare', label: 'Prohlédnout akce' },
        { icon: '💬', title: 'Výživové poradenství', desc: 'Osobní konzultace šité na míru vašemu dítěti. První schůzka bez závazků.', href: '/poradenstvi', label: 'Objednat se' },
      ].map(s => (
        <div class="card p-6">
          <div class="w-14 h-14 bg-[#e8f5ec] rounded-2xl flex items-center justify-center text-3xl mb-4">{s.icon}</div>
          <h3 class="text-xl font-bold text-[#2c2c2c] mb-2">{s.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">{s.desc}</p>
          <a href={s.href} class="text-[#3d7a4a] font-semibold text-sm hover:underline">{s.label} →</a>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA banner -->
  <div class="px-4 mb-8">
    <div class="bg-[#3d7a4a] py-16 px-8 rounded-3xl max-w-6xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-3">Přihlaste děti na letní tábor! 🌞</h2>
      <p class="text-green-200 mb-8 max-w-xl mx-auto">Místa se plní rychle. Pojistěte si místo pro vaše dítě ještě dnes.</p>
      <a href="/tabory" class="inline-flex items-center gap-2 bg-white text-[#3d7a4a] font-bold px-8 py-3 rounded-full hover:bg-gray-50 transition-colors shadow-lg">
        🏕️ Zobrazit tábory a přihlásit se
      </a>
    </div>
  </div>
</Layout>
