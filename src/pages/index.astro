---
import Layout from '../layouts/Layout.astro';
import { getDb } from '../lib/db';
import { formatDate, formatPrice } from '../lib/slugify';
import type { Camp, Seminar } from '../lib/db';

const db = getDb();
const camps = db.prepare("SELECT * FROM camps WHERE active=1 AND date(date_from) >= date('now') ORDER BY sort_order, date_from LIMIT 3").all() as Camp[];
const seminars = db.prepare("SELECT * FROM seminars WHERE active=1 AND date(date_from) >= date('now') ORDER BY sort_order, date_from LIMIT 3").all() as Seminar[];
const upcoming = [...camps.map(c => ({...c, kind: 'camp' as const})), ...seminars.map(s => ({...s, kind: 'seminar' as const}))]
  .sort((a, b) => a.date_from.localeCompare(b.date_from))
  .slice(0, 3)
  .map(item => ({
    ...item,
    spotsLeft: 'spots_left' in item ? (item as Camp).spots_left : null,
    fewSpots: 'spots_left' in item && (item as Camp).spots_left > 0 && (item as Camp).spots_left < 4,
    href: `/${item.kind === 'camp' ? 'tabory' : 'seminare'}/${item.slug}`,
    kindLabel: item.kind === 'camp' ? 'Tábor' : 'Seminář',
    kindClass: item.kind === 'camp' ? 'bg-[#e8f5ec] text-[#3d7a4a]' : 'bg-[#fef3dc] text-[#c07818]',
    kindEmoji: item.kind === 'camp' ? '🏕️' : '🎓',
  }));
---

<Layout title="Pro zdravé děti – Lenka Pokorná, výživová poradkyně" description="Certifikovaná výživová poradkyně Lenka Pokorná. Poradenství pro těhotné, kojící maminky, výživa dětí, příkrmy. Příměstské tábory a semináře v Písku.">

  <!-- ═══ HERO ═══ -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[#e8f5ec] via-[#faf8f3] to-[#fef3dc] pt-14 pb-20">
    <!-- Dekorativní kruhy -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#3d7a4a]/5 rounded-full -translate-y-1/3 translate-x-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-10 w-72 h-72 bg-[#f5a623]/8 rounded-full translate-y-1/2 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-4 relative">
      <div class="grid md:grid-cols-2 gap-10 items-center">

        <!-- Text -->
        <div>
          <span class="inline-flex items-center gap-2 bg-white text-[#3d7a4a] text-sm font-semibold px-4 py-1.5 rounded-full mb-6 shadow-sm border border-[#3d7a4a]/10">
            🌿 Certifikovaná výživová poradkyně
          </span>
          <h1 class="text-4xl md:text-5xl font-black text-[#2c2c2c] leading-tight mb-5">
            Naučte svou rodinu<br/>
            <span class="text-[#3d7a4a]">zdravý vztah k jídlu</span>
          </h1>
          <p class="text-xl text-gray-500 leading-relaxed mb-3">
            Jíst zdravě nemusí být žádná fuška.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed mb-8">
            Může to být kulinářské dobrodružství pro celou rodinu — od nejmenšího miminka až po školáka.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            <a href="/poradenstvi" class="btn-primary">💬 Objednat konzultaci</a>
            <a href="/tabory" class="btn-outline">🏕️ Letní tábory</a>
          </div>
          <!-- Důvěra -->
          <div class="flex flex-wrap items-center gap-5 text-sm text-gray-500">
            <div class="flex items-center gap-1.5">
              <span class="text-[#f5a623]">★★★★★</span>
              <span>Spokojení klienti</span>
            </div>
            <span class="text-gray-300">|</span>
            <div class="flex items-center gap-1.5">📍 Písek & online</div>
            <span class="text-gray-300">|</span>
            <div class="flex items-center gap-1.5">🎓 Od 2015</div>
          </div>
        </div>

        <!-- Foto hero -->
        <div class="relative flex justify-center">
          <div class="relative w-full max-w-sm">
            <div class="aspect-[3/4] rounded-[2.5rem] bg-gradient-to-br from-[#c8e6d0] to-[#e8f5ec] border-2 border-dashed border-[#3d7a4a]/25 flex flex-col items-center justify-center text-center p-8 shadow-xl">
              <div class="text-7xl mb-4">👩‍🍳</div>
              <p class="text-[#3d7a4a] font-bold">Foto Lenky — hlavní</p>
              <p class="text-gray-400 text-xs mt-1">Portrét, přirozené prostředí</p>
            </div>
            <!-- Float badge vlevo dole -->
            <div class="absolute -bottom-4 -left-6 bg-white rounded-2xl shadow-lg px-4 py-3 flex items-center gap-3">
              <div class="w-10 h-10 bg-[#e8f5ec] rounded-xl flex items-center justify-center text-xl">🥗</div>
              <div>
                <div class="text-xs text-gray-400">Specializace</div>
                <div class="text-sm font-bold text-[#2c2c2c]">Výživa dětí</div>
              </div>
            </div>
            <!-- Float badge vpravo nahoře -->
            <div class="absolute -top-4 -right-6 bg-white rounded-2xl shadow-lg px-4 py-3 flex items-center gap-3">
              <div class="w-10 h-10 bg-[#fef3dc] rounded-xl flex items-center justify-center text-xl">🏕️</div>
              <div>
                <div class="text-xs text-gray-400">Každé léto</div>
                <div class="text-sm font-bold text-[#2c2c2c]">Příměstské tábory</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ NADCHÁZEJÍCÍ AKCE ═══ -->
  {upcoming.length > 0 && (
    <section class="section">
      <div class="flex items-end justify-between mb-8 gap-4">
        <div>
          <h2 class="text-3xl font-black text-[#2c2c2c]">Nejbližší akce</h2>
          <p class="text-gray-500 mt-1">Míst je vždy málo — přihlaste se včas!</p>
        </div>
        <div class="hidden sm:flex gap-3 flex-shrink-0">
          <a href="/tabory" class="btn-outline text-sm">Všechny tábory</a>
          <a href="/seminare" class="btn-outline text-sm">Všechny semináře</a>
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {upcoming.map((item) => (
          <a href={item.href} class="card group cursor-pointer block">
            {item.poster_url ? (
              <img src={item.poster_url} alt={item.title} class="w-full aspect-[3/4] object-cover rounded-t-2xl" />
            ) : (
              <div class="w-full aspect-[3/4] bg-gradient-to-br from-[#e8f5ec] to-[#f0ebe0] rounded-t-2xl flex items-center justify-center text-6xl">
                {item.kindEmoji}
              </div>
            )}
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${item.kindClass}`}>{item.kindLabel}</span>
                {item.fewSpots && <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-red-50 text-red-600">Poslední {item.spotsLeft} místa!</span>}
              </div>
              <h3 class="font-bold text-lg text-[#2c2c2c] group-hover:text-[#3d7a4a] transition-colors mb-1">{item.title}</h3>
              <p class="text-sm text-gray-500 mb-3">📅 {formatDate(item.date_from)} · {item.location}</p>
              {item.price !== null && item.price !== undefined && (
                <p class="font-bold text-[#3d7a4a] text-lg">{formatPrice(item.price as number)}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ═══ O LENCE ═══ -->
  <section class="bg-[#faf8f3] py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">

        <!-- Foto -->
        <div class="flex justify-center">
          <div class="relative w-full max-w-xs">
            <div class="aspect-square rounded-[2.5rem] bg-gradient-to-br from-[#fef3dc] to-[#faf0e0] border-2 border-dashed border-[#f5a623]/30 flex flex-col items-center justify-center text-center p-8 shadow-lg">
              <div class="text-6xl mb-4">🌱</div>
              <p class="text-[#c07818] font-bold text-sm">Foto Lenky — přirozené</p>
              <p class="text-gray-400 text-xs mt-1">Neformální portrét s úsměvem</p>
            </div>
            <div class="absolute -bottom-3 -right-3 bg-[#3d7a4a] text-white rounded-2xl px-4 py-2 text-sm font-bold shadow-lg">
              Od roku 2015 🎓
            </div>
          </div>
        </div>

        <!-- Text -->
        <div>
          <span class="text-[#3d7a4a] font-semibold text-sm">👋 Ahoj!</span>
          <h2 class="text-3xl font-black text-[#2c2c2c] mt-2 mb-5">Jmenuji se Lenka</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            Jsem certifikovaná výživová poradkyně se specializací na výživu dětí. V oblasti výživy vás provedu od těhotenství přes kojení, výživu kojenců a dětí až po úpravu hmotnosti a zdravou rodinnou stravu.
          </p>
          <p class="text-gray-700 leading-relaxed mb-4">
            Propojuji klasický přístup ke stravě se zkušenostmi i netradičními výživovými metodami. Věřím, že správné stravování není o striktních dietách — je to o radosti z jídla a zdravých návycích od malička.
          </p>
          <p class="text-gray-700 leading-relaxed mb-6">
            Mé tábory a semináře jsou plné smíchu, vaření a nových chutí. Přijďte si to vyzkoušet!
          </p>
          <a href="/o-mne" class="btn-primary">Více o mně →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ CITÁT ═══ -->
  <section class="bg-[#3d7a4a] py-16 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="text-4xl mb-6">💬</div>
      <blockquote class="text-2xl md:text-3xl font-black leading-tight mb-6">
        "Nemůžete dobře myslet, spát, ani milovat,<br class="hidden md:block"/>
        <span class="text-[#a8d5b5]"> pokud jste se dobře nenajedli."</span>
      </blockquote>
      <p class="text-green-200 text-lg leading-relaxed max-w-2xl mx-auto">
        Ne, není to přehnané. Jíst nutričně nevhodné potraviny je podobné, jako do benzinového motoru tankovat naftu. Domluvme si schůzku — naučím vás, jak tělu dát vše, co potřebuje.
      </p>
    </div>
  </section>

  <!-- ═══ SLUŽBY ═══ -->
  <section class="section">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-black text-[#2c2c2c]">S čím vám pomohu?</h2>
      <p class="text-gray-500 mt-2 max-w-xl mx-auto">Od těhotenství po školní věk — provázím vás celou cestou. Osobně v Písku i online.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        {
          icon: '💬',
          title: 'Výživové poradenství',
          desc: 'Individuální konzultace šité přesně na míru. Od těhotenství, kojení, příkrmů až po výživa školáků a úpravu hmotnosti.',
          href: '/poradenstvi',
          label: 'Objednat se',
          color: 'bg-[#e8f5ec]',
        },
        {
          icon: '🏕️',
          title: 'Příměstské tábory',
          desc: 'Týdenní kulinářské dobrodružství pro děti plné vaření, poznávání potravin a zdravého jídla. Každé léto v Písku.',
          href: '/tabory',
          label: 'Tábory na léto',
          color: 'bg-[#fef3dc]',
        },
        {
          icon: '🎓',
          title: 'Semináře & workshopy',
          desc: 'Přednášky a praktické workshopy pro rodiče i školy. Největší téma: naučit vás jíst pestrou a zdravou stravu.',
          href: '/seminare',
          label: 'Prohlédnout akce',
          color: 'bg-[#f0e8fb]',
        },
      ].map(s => (
        <div class="card p-6 flex flex-col">
          <div class={`w-14 h-14 ${s.color} rounded-2xl flex items-center justify-center text-3xl mb-5`}>{s.icon}</div>
          <h3 class="text-xl font-bold text-[#2c2c2c] mb-2">{s.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-5 flex-1">{s.desc}</p>
          <a href={s.href} class="text-[#3d7a4a] font-bold text-sm hover:underline">{s.label} →</a>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ SPRÁVNÁ VÝŽIVA ═══ -->
  <section class="bg-[#faf8f3] py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-black text-[#2c2c2c] mb-5 leading-tight">
            Zaměřte se na<br/>
            <span class="text-[#3d7a4a]">správnou výživu</span><br/>
            a začnou se dít divy.
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            Specializuji se na výživu dětí do a od jednoho roku, ale i na výživu maminek v těhotenství, při kojení i na úpravu hmotnosti.
          </p>
          <p class="text-gray-700 leading-relaxed mb-6">
            Naučím vás, jak vy můžete naučit svou rodinu mít zdravý vztah k jídlu.
          </p>
          <div class="grid grid-cols-2 gap-3 mb-6">
            {[
              { icon: '🤰', label: 'Těhotenství' },
              { icon: '🍼', label: 'Kojení & příkrmy' },
              { icon: '🧒', label: 'Výživa dětí' },
              { icon: '⚖️', label: 'Úprava hmotnosti' },
            ].map(tag => (
              <div class="flex items-center gap-2 bg-white rounded-xl px-3 py-2.5 shadow-sm border border-gray-100 text-sm font-semibold text-[#2c2c2c]">
                <span>{tag.icon}</span> {tag.label}
              </div>
            ))}
          </div>
          <a href="/poradenstvi" class="btn-primary">Přečíst více o poradenství →</a>
        </div>

        <!-- Foto -->
        <div class="flex justify-center">
          <div class="aspect-[4/3] w-full max-w-sm rounded-[2.5rem] bg-gradient-to-br from-[#e8f5ec] to-[#d0ebd8] border-2 border-dashed border-[#3d7a4a]/25 flex flex-col items-center justify-center text-center p-8 shadow-lg">
            <div class="text-6xl mb-4">🥦</div>
            <p class="text-[#3d7a4a] font-bold text-sm">Foto z konzultace / workshopu</p>
            <p class="text-gray-400 text-xs mt-1">Přirozená atmosféra, vaření s dětmi</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA TÁBORY ═══ -->
  <div class="px-4 py-8">
    <div class="bg-gradient-to-br from-[#3d7a4a] to-[#2d5c38] py-14 px-8 rounded-3xl max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div class="text-white">
          <span class="inline-block bg-white/15 text-white text-xs font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">Léto 2025</span>
          <h2 class="text-3xl font-black mb-3">Přihlaste děti<br/>na letní tábor! 🌞</h2>
          <p class="text-green-200 leading-relaxed mb-6">
            Příměstské tábory plné vaření, poznávání potravin a zdravého jídla. Místa se plní rychle — pojistěte si místo pro vaše dítě ještě dnes.
          </p>
          <a href="/tabory" class="inline-flex items-center gap-2 bg-white text-[#3d7a4a] font-bold px-8 py-3 rounded-full hover:bg-gray-50 transition-colors shadow-lg">
            🏕️ Zobrazit tábory a přihlásit se
          </a>
        </div>
        <!-- Foto tábor -->
        <div class="flex justify-center">
          <div class="aspect-[4/3] w-full max-w-xs rounded-3xl bg-white/10 border-2 border-dashed border-white/30 flex flex-col items-center justify-center text-center p-8">
            <div class="text-6xl mb-3">🏕️</div>
            <p class="text-white font-bold text-sm">Foto z tábora</p>
            <p class="text-green-300 text-xs mt-1">Děti při vaření, skupinové foto</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ KONTAKT ═══ -->
  <section class="section text-center">
    <h2 class="text-3xl font-black text-[#2c2c2c] mb-3">Chcete si popovídat?</h2>
    <p class="text-gray-500 mb-8 max-w-md mx-auto">Na první dotazy odpovídám ráda zdarma. Napište mi nebo zavolejte.</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="mailto:info@prozdravedeti.cz" class="btn-primary">✉️ info@prozdravedeti.cz</a>
      <a href="tel:+420725757041" class="btn-outline">📞 +420 725 757 041</a>
    </div>
    <p class="text-xs text-gray-400 mt-5">IČ: 88631681 · Na Pakšovce 2270, 397 01 Písek</p>
  </section>

</Layout>
