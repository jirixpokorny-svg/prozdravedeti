---
import Layout from '../../layouts/Layout.astro';
import { getDb } from '../../lib/db';
import { formatDate, formatPrice } from '../../lib/slugify';
import type { Seminar } from '../../lib/db';

const { slug } = Astro.params;
const db = getDb();
const seminar = db.prepare("SELECT * FROM seminars WHERE slug = ? AND active = 1").get(slug) as Seminar | undefined;
if (!seminar) return Astro.redirect('/seminare');
---

<Layout title={`${seminar.title} – Pro zdravé děti`} description={seminar.description.slice(0, 160)}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <a href="/seminare" class="inline-flex items-center gap-2 text-[#3d7a4a] font-semibold text-sm mb-6 hover:underline">← Zpět na semináře</a>

    <div class="grid md:grid-cols-2 gap-10 items-start">
      <div>
        {seminar.poster_url
          ? <img src={seminar.poster_url} alt={seminar.title} class="w-full rounded-3xl shadow-lg" />
          : <div class="w-full aspect-[3/4] bg-gradient-to-br from-[#fef3dc] to-[#f0ebe0] rounded-3xl flex items-center justify-center text-8xl shadow-inner">🎓</div>
        }
      </div>

      <div class="sticky top-24">
        <span class="bg-[#fef3dc] text-[#c07818] text-xs font-bold px-3 py-1 rounded-full">Seminář / kurz</span>
        <h1 class="text-3xl font-black text-[#2c2c2c] mt-3 mb-4">{seminar.title}</h1>

        <div class="bg-[#fef3dc] rounded-2xl p-5 mb-6 space-y-2">
          <div class="flex items-center gap-3 text-sm"><span class="text-lg">📅</span><span class="font-semibold">{formatDate(seminar.date_from)}</span></div>
          {seminar.time_info && <div class="flex items-center gap-3 text-sm"><span class="text-lg">🕐</span><span>{seminar.time_info}</span></div>}
          <div class="flex items-center gap-3 text-sm"><span class="text-lg">📍</span><span>{seminar.location}</span></div>
          <div class="flex items-center gap-3">
            <span class="text-lg">💰</span>
            {seminar.price !== null
              ? <span class="text-xl font-black text-[#c07818]">{formatPrice(seminar.price)}</span>
              : <span class="text-sm font-semibold text-gray-600">Cena na vyžádání</span>
            }
          </div>
        </div>

        <div class="prose prose-sm text-gray-700 mb-6" set:html={seminar.description.replace(/\n/g, '<br/>')} />

        <div>
          <h2 class="text-xl font-bold text-[#2c2c2c] mb-4">Nezávazná přihláška</h2>
          <form id="order-form" class="space-y-4">
            <input type="hidden" name="item_id" value={seminar.id} />
            <input type="hidden" name="item_title" value={seminar.title} />
            <input type="hidden" name="type" value="seminar" />
            <input type="hidden" name="child_name" value="-" />
            <input type="hidden" name="child_age" value="-" />

            <div>
              <label class="label">Vaše jméno *</label>
              <input type="text" name="parent_name" required class="input" placeholder="Jana Nováková" />
            </div>
            <div>
              <label class="label">Email *</label>
              <input type="email" name="email" required class="input" placeholder="jana@email.cz" />
            </div>
            <div>
              <label class="label">Telefon *</label>
              <input type="tel" name="phone" required class="input" placeholder="+420 123 456 789" />
            </div>
            <div>
              <label class="label">Dotaz nebo poznámka</label>
              <textarea name="note" rows="3" class="input resize-none"></textarea>
            </div>

            <div id="form-error" class="hidden bg-red-50 text-red-700 rounded-xl p-3 text-sm"></div>
            <div id="form-success" class="hidden bg-[#e8f5ec] text-[#2d5c38] rounded-xl p-4 text-sm font-semibold"></div>

            <button type="submit" class="btn-warm w-full justify-center text-base">Odeslat přihlášku</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('order-form') as HTMLFormElement | null;
  const errBox = document.getElementById('form-error');
  const successBox = document.getElementById('form-success');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type=submit]') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Odesílám…';
    errBox?.classList.add('hidden'); successBox?.classList.add('hidden');
    try {
      const res = await fetch('/api/order', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(new FormData(form))) });
      const json = await res.json();
      if (res.ok) {
        form.reset(); form.classList.add('hidden');
        if (successBox) { successBox.textContent = '🎉 Přihláška odeslána! Potvrzení přijde na váš email.'; successBox.classList.remove('hidden'); }
      } else throw new Error(json.error || 'Chyba');
    } catch (err: any) {
      if (errBox) { errBox.textContent = err.message; errBox.classList.remove('hidden'); }
      btn.disabled = false; btn.textContent = 'Odeslat přihlášku';
    }
  });
</script>
