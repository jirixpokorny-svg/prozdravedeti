---
import Layout from '../../layouts/Layout.astro';
import { getDb } from '../../lib/db';
import { formatDate, formatPrice } from '../../lib/slugify';
import type { Seminar } from '../../lib/db';

const db = getDb();
const upcoming = db.prepare("SELECT * FROM seminars WHERE active=1 AND date(date_from) >= date('now') ORDER BY sort_order, date_from").all() as Seminar[];
const past = db.prepare("SELECT * FROM seminars WHERE active=1 AND date(date_from) < date('now') ORDER BY date_from DESC LIMIT 6").all() as Seminar[];
---

<Layout title="Semináře a kurzy – Pro zdravé děti" description="Semináře, workshopy a kurzy o výživě dětí. Online i prezenčně v Písku.">
  <section class="bg-gradient-to-br from-[#fef3dc] to-[#faf8f3] py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <span class="inline-flex items-center gap-2 bg-white text-[#c07818] text-sm font-semibold px-4 py-1.5 rounded-full mb-4 shadow-sm">
        🎓 Workshopy & přednášky
      </span>
      <h1 class="text-4xl md:text-5xl font-black text-[#2c2c2c] mb-4">Semináře & kurzy</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Praktické workshopy a přednášky o výživě dětí, zdravém vaření a výchově ke zdravému stravování.
      </p>
    </div>
  </section>

  <section class="section">
    {upcoming.length === 0 ? (
      <div class="text-center py-16">
        <div class="text-6xl mb-4">📆</div>
        <h2 class="text-2xl font-bold text-gray-700 mb-2">Brzy přidáme nové termíny</h2>
        <p class="text-gray-500">Napište nám na <a href="mailto:info@prozdravedeti.cz" class="text-[#3d7a4a] font-semibold">info@prozdravedeti.cz</a></p>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 gap-6 mb-12">
        {upcoming.map(seminar => (
          <a href={`/seminare/${seminar.slug}`} class="card group flex gap-5 p-5">
            {seminar.poster_url ? (
              <img src={seminar.poster_url} alt={seminar.title} class="w-24 h-32 object-cover rounded-xl flex-shrink-0" />
            ) : (
              <div class="w-24 h-32 bg-gradient-to-br from-[#fef3dc] to-[#f0ebe0] rounded-xl flex items-center justify-center text-4xl flex-shrink-0">🎓</div>
            )}
            <div class="flex-1">
              <h3 class="font-bold text-lg text-[#2c2c2c] group-hover:text-[#3d7a4a] transition-colors mb-2">{seminar.title}</h3>
              <p class="text-sm text-gray-500 mb-1">📅 {formatDate(seminar.date_from)}</p>
              {seminar.time_info && <p class="text-sm text-gray-500 mb-1">🕐 {seminar.time_info}</p>}
              <p class="text-sm text-gray-500 mb-3">📍 {seminar.location}</p>
              {seminar.price !== null
                ? <span class="font-bold text-[#3d7a4a]">{formatPrice(seminar.price)}</span>
                : <span class="text-sm text-[#3d7a4a] font-semibold">Zdarma / na vyžádání</span>
              }
            </div>
          </a>
        ))}
      </div>
    )}

    {past.length > 0 && (
      <div class="border-t border-gray-200 pt-8">
        <h2 class="text-lg font-bold text-gray-400 mb-4">Proběhlé akce</h2>
        <div class="grid md:grid-cols-2 gap-3">
          {past.map(s => (
            <div class="flex items-center gap-3 p-3 rounded-xl text-gray-400">
              <span class="text-2xl">🎓</span>
              <div>
                <p class="font-semibold text-sm">{s.title}</p>
                <p class="text-xs">{formatDate(s.date_from)} · {s.location}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
</Layout>
