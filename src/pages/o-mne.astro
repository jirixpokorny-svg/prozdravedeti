---
import Layout from '../layouts/Layout.astro';
---

<Layout title="O mně – Lenka Pokorná | Pro zdravé děti" description="Certifikovaná výživová poradkyně se specializací na výživu dětí. Lenka Pokorná, Písek.">
  <section class="bg-gradient-to-br from-[#e8f5ec] to-[#faf8f3] py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="text-4xl font-black text-[#2c2c2c] mb-3">O mně</h1>
      <p class="text-gray-600 text-lg">Ahoj, jsem Lenka – mám výživu dětí opravdu ráda 🌿</p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 py-12">
    <div class="card p-8 mb-8">
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <div class="w-32 h-32 rounded-3xl bg-gradient-to-br from-[#3d7a4a]/20 to-[#f5a623]/20 flex items-center justify-center text-6xl flex-shrink-0 mx-auto md:mx-0">
          👩‍🍳
        </div>
        <div>
          <h2 class="text-2xl font-black text-[#2c2c2c] mb-3">Lenka Pokorná</h2>
          <p class="text-[#3d7a4a] font-semibold mb-4">Certifikovaná výživová poradkyně · IČ: 88631681</p>
          <p class="text-gray-700 leading-relaxed mb-4">
            Věřím, že zdravé stravování začíná v dětství — a že může být zábavné! Moje práce mě naplňuje, protože vidím, jak se děti (a jejich rodiče) mění, jakmile objeví radost z dobrého, výživného jídla.
          </p>
          <p class="text-gray-700 leading-relaxed">
            Specializuji se na výživu od těhotenství přes kojení, příkrmy, výživu malých dětí až po zdravou školní stravu. Propojuji klasický přístup s moderními poznatky a vždy hledám řešení, která jsou reálná pro každodenní život rodiny.
          </p>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-8">
      {[
        { icon: '🎓', title: 'Vzdělání', items: ['Certifikovaná výživová poradkyně', 'Specializace na výživu dětí', 'Průběžné vzdělávání a kurzy'] },
        { icon: '💚', title: 'Specializace', items: ['Výživa kojenců a batolat', 'Výživa v těhotenství a kojení', 'Zdravá rodinná strava', 'Příměstské tábory pro děti'] },
      ].map(box => (
        <div class="card p-6">
          <div class="text-3xl mb-3">{box.icon}</div>
          <h3 class="font-bold text-lg mb-3">{box.title}</h3>
          <ul class="space-y-1.5">
            {box.items.map(item => (
              <li class="flex items-center gap-2 text-gray-600 text-sm">
                <span class="w-1.5 h-1.5 bg-[#3d7a4a] rounded-full flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="bg-[#e8f5ec] rounded-2xl p-6 text-center">
      <p class="text-gray-700 mb-4">Chcete se objednat nebo se jen zeptat?</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="mailto:info@prozdravedeti.cz" class="btn-primary">✉️ info@prozdravedeti.cz</a>
        <a href="tel:+420725757041" class="btn-outline">📞 +420 725 757 041</a>
      </div>
    </div>
  </section>
</Layout>
