---
import { validateSession, getSessionFromRequest } from '../../../lib/auth';
if (!validateSession(getSessionFromRequest(Astro.request))) return Astro.redirect('/admin/login');
import { getDb } from '../../../lib/db';
import { slugify } from '../../../lib/slugify';
import fs from 'fs';
import path from 'path';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const title = form.get('title') as string;
  const date_from = form.get('date_from') as string;
  const date_to = (form.get('date_to') as string) || null;
  const time_info = (form.get('time_info') as string) || null;
  const location = form.get('location') as string;
  const price = Number(form.get('price'));
  const spots_total = Number(form.get('spots_total'));
  const spots_left = Number(form.get('spots_left'));
  const age_range = (form.get('age_range') as string) || null;
  const description = form.get('description') as string;
  const active = form.get('active') === '1' ? 1 : 0;
  const sort_order = Number(form.get('sort_order')) || 0;

  let poster_url: string | null = null;
  const posterFile = form.get('poster') as File | null;
  if (posterFile && posterFile.size > 0) {
    const ext = posterFile.name.split('.').pop();
    const filename = `camp-${Date.now()}.${ext}`;
    const uploadDir = path.join(process.cwd(), 'public/uploads');
    fs.mkdirSync(uploadDir, { recursive: true });
    fs.writeFileSync(path.join(uploadDir, filename), Buffer.from(await posterFile.arrayBuffer()));
    poster_url = `/uploads/${filename}`;
  }

  const slug = slugify(title) + '-' + date_from.slice(0, 7).replace('-', '-');
  const db = getDb();
  db.prepare(`INSERT INTO camps (slug,title,date_from,date_to,time_info,location,price,spots_total,spots_left,age_range,description,poster_url,active,sort_order)
    VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)`).run(slug, title, date_from, date_to, time_info, location, price, spots_total, spots_left, age_range, description, poster_url, active, sort_order);

  return Astro.redirect('/admin/tabory');
}

import AdminCampForm from '../../../components/AdminCampForm.astro';
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nový tábor – Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <div style="position:fixed;left:0;top:0;bottom:0;width:240px;background:#2d5c38;padding:24px 0;">
    <div style="padding:0 20px 24px;border-bottom:1px solid rgba(255,255,255,0.1)">
      <img src="/images/logo.png" style="height:40px;filter:brightness(0) invert(1)" alt="Logo" />
    </div>
    <nav style="padding:16px 12px">
      <a href="/admin" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;color:rgba(255,255,255,0.7);text-decoration:none;font-size:14px;font-weight:600;margin-bottom:2px">🏠 Přehled</a>
      <a href="/admin/tabory" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;background:rgba(255,255,255,0.15);color:white;text-decoration:none;font-size:14px;font-weight:600;margin-bottom:2px">🏕️ Tábory</a>
      <a href="/admin/seminare" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;color:rgba(255,255,255,0.7);text-decoration:none;font-size:14px;font-weight:600;margin-bottom:2px">🎓 Semináře</a>
      <a href="/admin/prihlasky" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;color:rgba(255,255,255,0.7);text-decoration:none;font-size:14px;font-weight:600;margin-bottom:2px">📋 Přihlášky</a>
      <a href="/admin/logout" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;color:rgba(255,255,255,0.7);text-decoration:none;font-size:14px;font-weight:600;margin-top:16px">🚪 Odhlásit</a>
    </nav>
  </div>
  <main style="margin-left:240px;padding:32px;max-width:900px">
    <AdminCampForm action="/admin/tabory/novy" backUrl="/admin/tabory" />
  </main>
</body>
</html>
