---
import { validateSession, getSessionFromRequest } from '../../lib/auth';
const token = getSessionFromRequest(Astro.request);
if (!validateSession(token)) return Astro.redirect('/admin/login');

import { getDb } from '../../lib/db';
import { formatDate } from '../../lib/slugify';
import type { Camp, Seminar, Order } from '../../lib/db';

const db = getDb();
const camps = db.prepare("SELECT * FROM camps ORDER BY date_from DESC LIMIT 10").all() as Camp[];
const seminars = db.prepare("SELECT * FROM seminars ORDER BY date_from DESC LIMIT 10").all() as Seminar[];
const orders = db.prepare("SELECT * FROM orders ORDER BY created_at DESC LIMIT 20").all() as Order[];
const newOrders = orders.filter(o => o.status === 'new').length;
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin – Pro zdravé děti</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/_astro/admin.css" />
  <style>
    * { box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #f3f4f6; color: #2c2c2c; margin: 0; }
    .sidebar { position: fixed; left: 0; top: 0; bottom: 0; width: 240px; background: #2d5c38; color: white; padding: 24px 0; display: flex; flex-direction: column; }
    .sidebar-logo { padding: 0 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .sidebar-logo img { height: 40px; width: auto; filter: brightness(0) invert(1); }
    .sidebar-logo span { display: block; font-size: 11px; color: rgba(255,255,255,0.5); margin-top: 4px; }
    .sidebar nav { padding: 16px 12px; flex: 1; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 10px; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; font-weight: 600; transition: all 0.15s; margin-bottom: 2px; }
    .nav-item:hover, .nav-item.active { background: rgba(255,255,255,0.15); color: white; }
    .nav-item span { font-size: 18px; }
    .sidebar-footer { padding: 12px; border-top: 1px solid rgba(255,255,255,0.1); }
    .main { margin-left: 240px; padding: 32px; min-height: 100vh; }
    .page-title { font-family: 'Nunito', sans-serif; font-size: 28px; font-weight: 800; color: #2c2c2c; margin: 0 0 8px; }
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: white; border-radius: 16px; padding: 20px; }
    .stat-value { font-size: 32px; font-weight: 800; color: #3d7a4a; font-family: 'Nunito', sans-serif; }
    .stat-label { font-size: 13px; color: #6b7280; margin-top: 4px; }
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .section-title { font-family: 'Nunito', sans-serif; font-size: 20px; font-weight: 800; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 18px; border-radius: 999px; font-size: 14px; font-weight: 600; border: none; cursor: pointer; text-decoration: none; transition: all 0.15s; }
    .btn-green { background: #3d7a4a; color: white; }
    .btn-green:hover { background: #2d5c38; }
    .btn-sm { padding: 5px 12px; font-size: 12px; }
    .btn-red { background: #fee2e2; color: #dc2626; }
    .btn-red:hover { background: #fecaca; }
    .btn-gray { background: #f3f4f6; color: #374151; }
    .btn-gray:hover { background: #e5e7eb; }
    .table-wrap { background: white; border-radius: 16px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    thead { background: #f9fafb; }
    th { padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; }
    td { padding: 14px 16px; font-size: 14px; border-top: 1px solid #f3f4f6; }
    tr:hover td { background: #fafafa; }
    .badge { display: inline-flex; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; }
    .badge-green { background: #dcfce7; color: #166534; }
    .badge-orange { background: #fef3c7; color: #92400e; }
    .badge-red { background: #fee2e2; color: #991b1b; }
    .badge-gray { background: #f3f4f6; color: #6b7280; }
    .mb-8 { margin-bottom: 32px; }
  </style>
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-logo">
      <img src="/images/logo.png" alt="Pro zdravé děti" />
      <span>Administrace</span>
    </div>
    <nav>
      <a href="/admin" class="nav-item active"><span>🏠</span> Přehled</a>
      <a href="/admin/tabory" class="nav-item"><span>🏕️</span> Tábory</a>
      <a href="/admin/seminare" class="nav-item"><span>🎓</span> Semináře</a>
      <a href="/admin/prihlasky" class="nav-item">
        <span>📋</span> Přihlášky
        {newOrders > 0 && <span style="background:#f5a623;color:white;border-radius:999px;padding:1px 7px;font-size:11px;margin-left:auto;">{newOrders}</span>}
      </a>
      <a href="/admin/nastaveni" class="nav-item"><span>⚙️</span> Nastavení</a>
    </nav>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="nav-item"><span>🚪</span> Odhlásit se</a>
      <a href="/" target="_blank" class="nav-item" style="margin-top:4px"><span>🌐</span> Zobrazit web</a>
    </div>
  </div>

  <main class="main">
    <h1 class="page-title">Dobrý den, Lenko! 👋</h1>
    <p style="color:#6b7280;margin-bottom:24px;font-size:14px;">Zde spravujete obsah webu prozdravedeti.cz</p>

    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-value">{camps.filter(c => c.active && new Date(c.date_from) >= new Date()).length}</div>
        <div class="stat-label">Nadcházející tábory</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{seminars.filter(s => s.active && new Date(s.date_from) >= new Date()).length}</div>
        <div class="stat-label">Nadcházející semináře</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style="color:{newOrders > 0 ? '#f5a623' : '#3d7a4a'}">{newOrders}</div>
        <div class="stat-label">Nové přihlášky</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{orders.length}</div>
        <div class="stat-label">Přihlášky celkem</div>
      </div>
    </div>

    <!-- Tábory -->
    <div class="mb-8">
      <div class="section-header">
        <span class="section-title">🏕️ Tábory</span>
        <a href="/admin/tabory/novy" class="btn btn-green">+ Přidat tábor</a>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Název</th><th>Datum</th><th>Cena</th><th>Míst</th><th>Stav</th><th></th></tr>
          </thead>
          <tbody>
            {camps.length === 0 && <tr><td colspan="6" style="text-align:center;color:#9ca3af;padding:32px">Zatím žádné tábory</td></tr>}
            {camps.map(c => (
              <tr>
                <td style="font-weight:600">{c.title}</td>
                <td style="color:#6b7280">{formatDate(c.date_from)}</td>
                <td>{c.price.toLocaleString('cs-CZ')} Kč</td>
                <td><span class={`badge ${c.spots_left === 0 ? 'badge-red' : c.spots_left <= 3 ? 'badge-orange' : 'badge-green'}`}>{c.spots_left}/{c.spots_total}</span></td>
                <td><span class={`badge ${c.active ? 'badge-green' : 'badge-gray'}`}>{c.active ? 'Aktivní' : 'Skrytý'}</span></td>
                <td><a href={`/admin/tabory/${c.id}`} class="btn btn-gray btn-sm">Upravit</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Poslední přihlášky -->
    <div>
      <div class="section-header">
        <span class="section-title">📋 Poslední přihlášky</span>
        <a href="/admin/prihlasky" class="btn btn-gray btn-sm">Všechny přihlášky</a>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Jméno rodiče</th><th>Dítě</th><th>Akce</th><th>Email</th><th>Datum</th><th>Stav</th></tr>
          </thead>
          <tbody>
            {orders.length === 0 && <tr><td colspan="6" style="text-align:center;color:#9ca3af;padding:32px">Zatím žádné přihlášky</td></tr>}
            {orders.slice(0, 8).map(o => (
              <tr>
                <td style="font-weight:600">{o.parent_name}</td>
                <td style="color:#6b7280">{o.child_name !== '-' ? `${o.child_name}, ${o.child_age} let` : '—'}</td>
                <td style="font-size:13px">{o.item_title}</td>
                <td><a href={`mailto:${o.email}`} style="color:#3d7a4a">{o.email}</a></td>
                <td style="color:#6b7280;font-size:13px">{new Date(o.created_at).toLocaleDateString('cs-CZ')}</td>
                <td><span class={`badge ${o.status === 'new' ? 'badge-orange' : 'badge-green'}`}>{o.status === 'new' ? 'Nová' : 'Vyřízeno'}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </main>
</body>
</html>
